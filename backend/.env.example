PORT=4010
AUTH_JWT_SECRET=some_long_random_secret_please_change
# Optional legacy demo user (password login removed; OTP creates users)
AUTH_DEMO_EMAIL=demo@bloomber.local
AUTH_DEMO_PASSWORD=demo1234
# OTP: OTP_DEBUG=0 hides devOtp in API even in dev. OTP_DEBUG=1 always shows devOtp.
# OTP_DEBUG=1
#
# Real email (pick one): Resend is easiest — get API key at https://resend.com
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=onboarding@resend.dev
#
# Or SMTP:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash